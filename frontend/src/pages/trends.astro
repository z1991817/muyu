---
import BaseLayout from "../components/BaseLayout.astro";
import HotBoard from "../components/HotBoard.astro";
import TopBar from "../components/TopBar.astro";
import { fetchTrends } from "../lib/api";
import { PLATFORM_CLASS_MAP, PLATFORM_NAME_MAP } from "../lib/platforms";
import type { Trend } from "../lib/types";

import "../styles/global.css";

const data = await fetchTrends().catch(() => ({ items: [], stale: true, updatedAt: new Date().toISOString() }));
const grouped = data.items.reduce<Record<string, Trend[]>>((acc, item) => {
  if (!acc[item.platform]) acc[item.platform] = [];
  acc[item.platform].push(item);
  return acc;
}, {});
---

<BaseLayout title="摸鱼热榜 | 全部热榜" description="全部平台热榜聚合" canonical="https://example.com/trends">
  <main class="wrap">
    <TopBar stale={data.stale} updatedAt={data.updatedAt} activePath="/trends" />
    <section class="boards">
      {Object.keys(grouped).map((platform) => (
        <HotBoard title={PLATFORM_NAME_MAP[platform] ?? platform} platformClass={PLATFORM_CLASS_MAP[platform] ?? "b-weibo"} items={grouped[platform]} />
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .boards {
    margin-top: 16px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  @media (max-width: 1100px) {
    .boards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>
