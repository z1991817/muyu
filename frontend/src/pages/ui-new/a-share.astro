---
import UiNewSeo from "../../components/ui-new/UiNewSeo.astro";
import UiNewFooter from "../../components/ui-new/UiNewFooter.astro";
import UiNewTopBar from "../../components/ui-new/UiNewTopBar.astro";
import { fetchCnMarket } from "../../lib/api";
import { cnStockUrl, sinaIndexUrl } from "../../lib/cn-market-links";
import { SITE_NAME, SITE_URL } from "../../lib/seo";
import type { CnMarketIndex, CnMarketResponse, CnMarketStock } from "../../lib/types";

const nowIso = new Date().toISOString();

type ApiRecord = Record<string, unknown>;
type FieldEntry = {
  key: string;
  label: string;
  value: string;
};

const fallbackMarket: CnMarketResponse = {
  indices: [],
  stocks: [],
  analysis: {
    fundFlows: [],
    limitUp: [],
    limitDown: [],
  },
  stale: true,
  updatedAt: nowIso,
};

const marketData = await Promise.race([
  fetchCnMarket(),
  new Promise<CnMarketResponse>((resolve) => {
    setTimeout(() => resolve(fallbackMarket), 1500);
  }),
]).catch(() => fallbackMarket);
const indices = marketData.indices;
const stocks = marketData.stocks;
const marketBreadth = marketData.analysis.fundFlows;
const limitUp = marketData.analysis.limitUp;
const limitDown = marketData.analysis.limitDown;
const updatedAt = marketData.updatedAt || nowIso;
const disclaimer =
  indices[0]?.disclaimer || stocks[0]?.disclaimer || "行情仅供查看，不构成投资建议";
const pageTitle = "A股行情 - 大盘指数与热门股票 | 摸鱼热榜";
const pageDescription = "查看 A股大盘指数、热门股票、市场广度、涨停股票和跌停股票，快速了解今天市场热不热。";
function formatSigned(value: number): string {
  const fixed = Math.abs(value).toFixed(2);
  return value >= 0 ? `+${fixed}` : `-${fixed}`;
}

function formatPercent(value: number): string {
  return `${formatSigned(value)}%`;
}

function formatPrice(value: number): string {
  return value.toLocaleString("zh-CN", {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
}

function formatNumericValue(value: string): string {
  const normalized = value.trim().replaceAll(",", "");
  if (!/^[-+]?\d+(?:\.\d+)?(?:e[-+]?\d+)?$/i.test(normalized)) return value;
  const numericValue = Number(normalized);
  if (!Number.isFinite(numericValue)) return value;
  return numericValue.toLocaleString("zh-CN", {
    maximumFractionDigits: 1,
    minimumFractionDigits: 0,
  });
}

function formatTenThousandYuan(value: string): string {
  const normalized = value.trim().replaceAll(",", "");
  if (!/^[-+]?\d+(?:\.\d+)?(?:e[-+]?\d+)?$/i.test(normalized)) return value;
  const numericValue = Number(normalized);
  if (!Number.isFinite(numericValue)) return value;
  return (numericValue / 10000).toLocaleString("zh-CN", {
    maximumFractionDigits: 1,
    minimumFractionDigits: 0,
    useGrouping: false,
  });
}

function formatUpdatedTime(iso: string): string {
  const date = new Date(iso);
  if (Number.isNaN(date.getTime())) return "--:--";
  return date.toLocaleTimeString("zh-CN", {
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  });
}

function movementClass(item: CnMarketIndex | CnMarketStock): string {
  return item.changePct >= 0 ? "is-up" : "is-down";
}

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  url: `${SITE_URL}/ui-new/a-share`,
  description: pageDescription,
  inLanguage: "zh-CN",
  isPartOf: {
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
  },
  about: ["A股行情", "大盘指数", "热门股票", "市场广度", "涨停股票", "跌停股票"],
  hasPart: [
    {
      "@type": "ItemList",
      name: "A股大盘指数",
      numberOfItems: indices.length,
      itemListElement: indices.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.name,
        url: sinaIndexUrl(item.symbol),
      })),
    },
    {
      "@type": "ItemList",
      name: "A股热门股票",
      numberOfItems: stocks.length,
      itemListElement: stocks.slice(0, 20).map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: `${item.name} ${item.symbol}`,
        url: cnStockUrl(item),
      })),
    },
  ],
};

function fieldLabel(key: string): string {
  const labels: Record<string, string> = {
    change: "涨跌额",
    changePct: "涨跌幅",
    disclaimer: "免责声明",
    direction: "方向",
    marketStatus: "市场状态",
    name: "名称",
    price: "最新价",
    reason: "原因",
    source: "来源",
    symbol: "代码",
    tradeDate: "交易日",
    turnover: "成交额",
    updatedAt: "更新时间",
    url: "链接",
    value: "金额",
    volume: "成交量",
  };
  return labels[key] ?? key.replace(/([A-Z])/g, " $1").trim();
}

function fieldDisplayValue(key: string, value: unknown): string {
  if (key === "direction") {
    if (value === "in") return "流入";
    if (value === "out") return "流出";
  }
  if (key === "changePct" && typeof value === "number") {
    return formatPercent(value);
  }
  return compactValue(value);
}

function isRecord(value: unknown): value is ApiRecord {
  return typeof value === "object" && value !== null && !Array.isArray(value);
}

function compactValue(value: unknown): string {
  if (value === null) return "null";
  if (value === undefined) return "";
  if (typeof value === "string") return value;
  if (typeof value === "number") return Number.isFinite(value) ? value.toString() : "--";
  if (typeof value === "boolean") return value ? "true" : "false";
  if (Array.isArray(value)) return `${value.length} 项`;
  if (isRecord(value)) return JSON.stringify(value);
  return String(value);
}

function extraFields(value: unknown, knownKeys: readonly string[]): FieldEntry[] {
  if (!isRecord(value)) return [];
  const known = new Set(knownKeys);
  return Object.entries(value)
    .filter(([key, fieldValue]) => !known.has(key) && fieldValue !== undefined && fieldValue !== "")
    .map(([key, fieldValue]) => ({
      key,
      label: fieldLabel(key),
      value: compactValue(fieldValue),
    }));
}

function standardFields(value: unknown, keys: readonly string[]): FieldEntry[] {
  if (!isRecord(value)) return [];
  return keys
    .filter((key) => key in value)
    .map((key) => ({
      key,
      label: fieldLabel(key),
      value: fieldDisplayValue(key, value[key]),
    }));
}

function indexDetailFields(item: CnMarketIndex): FieldEntry[] {
  return extraFields(item, [
      "symbol",
      "name",
      "price",
      "change",
      "changePct",
      "url",
      "updatedAt",
      "disclaimer",
    ]);
}

function stockDetailFields(item: CnMarketStock): FieldEntry[] {
  return extraFields(item, [
      "symbol",
      "name",
      "price",
      "change",
      "changePct",
      "volume",
      "turnover",
      "url",
      "updatedAt",
      "disclaimer",
    ]);
}

function limitDetailFields(item: unknown): FieldEntry[] {
  return standardFields(item, ["symbol"]).concat(
    extraFields(item, ["symbol", "name", "price", "changePct", "reason", "url"]),
  );
}

function fundFlowDetailFields(item: unknown): FieldEntry[] {
  return standardFields(item, []).concat(
    extraFields(item, ["name", "value", "changePct", "direction"]),
  );
}

const analysisExtraGroups = Object.entries(marketData.analysis as unknown as ApiRecord)
  .filter(([key]) => !["fundFlows", "limitUp", "limitDown"].includes(key))
  .map(([key, value]) => ({
    key,
    label: fieldLabel(key),
    entries: Array.isArray(value)
      ? value.map((item, index) => ({
          key: `${key}-${index}`,
          title: isRecord(item) ? compactValue(item.name ?? item.symbol ?? `${index + 1}`) : `${index + 1}`,
          fields: isRecord(item)
            ? Object.entries(item).map(([fieldKey, fieldValue]) => ({
                key: fieldKey,
                label: fieldLabel(fieldKey),
                value: compactValue(fieldValue),
              }))
            : [{ key: "value", label: "值", value: compactValue(item) }],
        }))
      : [
          {
            key,
            title: fieldLabel(key),
            fields: isRecord(value)
              ? Object.entries(value).map(([fieldKey, fieldValue]) => ({
                  key: fieldKey,
                  label: fieldLabel(fieldKey),
                  value: compactValue(fieldValue),
                }))
              : [{ key: "value", label: "值", value: compactValue(value) }],
          },
        ],
  }));

function sparkPoints(seed: string, up: boolean): string {
  const total = Array.from(seed).reduce((sum, char) => sum + char.charCodeAt(0), 0);
  const points = Array.from({ length: 8 }, (_, index) => {
    const x = index * 18;
    const wave = Math.sin((total + index * 17) / 11) * 9;
    const slope = up ? 27 - index * 2.6 : 17 + index * 2.4;
    const y = Math.max(8, Math.min(42, slope + wave));
    return `${x},${y.toFixed(1)}`;
  });
  return points.join(" ");
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <UiNewSeo title={pageTitle} description={pageDescription} canonical="/ui-new/a-share" structuredData={structuredData} />
    <link rel="stylesheet" href="/ui-new/base.css" />
    <link rel="stylesheet" href="/ui-new/a-share.css" />
  </head>
  <body>
    <div class="market-shell">
      <UiNewTopBar active="a-share" />

      <main class="market-layout">
        <header class="market-hero">
          <div class="hero-copy">
            <h1>A股行情</h1>
            <p>看一眼大盘涨跌、热门股票和市场广度，快速了解今天市场热不热。</p>
          </div>
          <div class="market-meta" aria-label="行情更新时间">
            <span>最近刷新 {formatUpdatedTime(updatedAt)}</span>
          </div>
        </header>

        <section class="index-section" aria-labelledby="indices-title">
          <div class="section-head">
            <div>
              <h2 id="indices-title">大盘指数</h2>
            </div>
          </div>

          {indices.length > 0 ? (
            <div class="index-grid">
              {indices.map((item) => {
                const up = item.changePct >= 0;
                const details = indexDetailFields(item);
                return (
                  <a class:list={["index-card", movementClass(item)]} href={sinaIndexUrl(item.symbol)} target="_blank" rel="noopener noreferrer">
                    <div class="index-card-head">
                      <span class="symbol">{item.symbol}</span>
                      <span>{up ? "上涨" : "下跌"}</span>
                    </div>
                    <h3>{item.name}</h3>
                    <div class="index-price">{formatPrice(item.price)}</div>
                    <div class="delta-row">
                      <span>{up ? "▲" : "▼"} {formatSigned(item.change)}</span>
                      <strong>{formatPercent(item.changePct)}</strong>
                    </div>
                    <svg class="sparkline" viewBox="0 0 126 52" preserveAspectRatio="none" aria-hidden="true">
                      <polyline points={sparkPoints(item.symbol, up)} />
                    </svg>
                    {details.length > 0 && (
                      <dl class="inline-fields">
                        {details.map((field) => (
                          <div title={field.value}>
                            <dt>{field.label}</dt>
                            <dd>{field.value}</dd>
                          </div>
                        ))}
                      </dl>
                    )}
                  </a>
                );
              })}
            </div>
          ) : (
            <div class="empty-panel">暂时还没有大盘指数。</div>
          )}
        </section>

        <section class="stocks-section" aria-labelledby="stocks-title">
          <div class="section-head compact">
            <div>
              <h2 id="stocks-title">热门股票</h2>
            </div>
          </div>

          {stocks.length > 0 ? (
            <div class="stock-table" role="table" aria-label="A股热门股票">
              <div class="stock-row stock-row-head" role="row">
                <span role="columnheader">股票</span>
                <span role="columnheader">最新价</span>
                <span role="columnheader">涨跌额</span>
                <span role="columnheader">涨跌幅</span>
                <span role="columnheader">成交额（万元）</span>
                <span role="columnheader">成交量（手）</span>
              </div>
              {stocks.map((item) => {
                const up = item.changePct >= 0;
                const details = stockDetailFields(item);
                return (
                  <a class:list={["stock-row", movementClass(item)]} href={cnStockUrl(item)} target="_blank" rel="noopener noreferrer" role="row">
                    <span class="stock-name" role="cell">
                      <strong>{item.symbol}</strong>
                      <small>{item.name}</small>
                    </span>
                    <span class="stock-price" role="cell" data-label="最新价">{formatPrice(item.price)}</span>
                    <span class="stock-delta" role="cell" data-label="涨跌额">{formatSigned(item.change)}</span>
                    <span class="stock-change" role="cell" data-label="涨跌幅">
                      {up ? "▲" : "▼"} {formatPercent(item.changePct)}
                    </span>
                    <span class="stock-turnover" role="cell" data-label="成交额（万元）" title={`${item.turnover} 元`}>
                      {formatTenThousandYuan(item.turnover)}
                    </span>
                    <span class="stock-volume" role="cell" data-label="成交量（手）">{item.volume}</span>
                    {details.length > 0 && (
                      <span class="stock-fields" role="cell">
                        {details.map((field) => (
                          <span title={field.value}>
                            <strong>{field.label}</strong>
                            {field.value}
                          </span>
                        ))}
                      </span>
                    )}
                  </a>
                );
              })}
            </div>
          ) : (
            <div class="empty-panel">暂时还没有热门股票。</div>
          )}
        </section>

        <section class="analysis-section" aria-labelledby="analysis-title">
          <div class="section-head compact">
            <div>
              <h2 id="analysis-title">市场概况</h2>
            </div>
          </div>

          <div class="analysis-grid">
            <article class="analysis-card">
              <div class="analysis-card-head">
                <h3>市场广度</h3>
              </div>
              <div class="analysis-list">
                {marketBreadth.length > 0 ? marketBreadth.map((item) => (
                  <div class:list={["analysis-row", item.direction === "out" ? "is-down" : item.direction === "flat" ? "" : "is-up"]}>
                    <span>{item.name}</span>
                    <strong title={item.value}>{formatNumericValue(item.value)}</strong>
                    <small>占比 {formatPercent(item.changePct)}</small>
                    {fundFlowDetailFields(item).map((field) => (
                      <small title={field.value}>{field.label}: {field.value}</small>
                    ))}
                  </div>
                )) : <p>暂时还没有市场广度。</p>}
              </div>
            </article>

            <article class="analysis-card">
              <div class="analysis-card-head">
                <h3>涨停股票</h3>
              </div>
              <div class="analysis-list">
                {limitUp.length > 0 ? limitUp.map((item) => {
                  const details = limitDetailFields(item);
                  return (
                    <a class="analysis-row is-up" href={cnStockUrl(item)} target="_blank" rel="noopener noreferrer">
                      <span>{item.name}</span>
                      <strong>{formatPrice(item.price)}</strong>
                      <small>{item.reason}</small>
                      <small>{formatPercent(item.changePct)}</small>
                      {details.map((field) => (
                        <small title={field.value}>{field.label}: {field.value}</small>
                      ))}
                    </a>
                  );
                }) : <p>暂时还没有涨停股票。</p>}
              </div>
            </article>

            <article class="analysis-card">
              <div class="analysis-card-head">
                <h3>跌停股票</h3>
              </div>
              <div class="analysis-list">
                {limitDown.length > 0 ? limitDown.map((item) => {
                  const details = limitDetailFields(item);
                  return (
                    <a class="analysis-row is-down" href={cnStockUrl(item)} target="_blank" rel="noopener noreferrer">
                      <span>{item.name}</span>
                      <strong>{formatPrice(item.price)}</strong>
                      <small>{item.reason}</small>
                      <small>{formatPercent(item.changePct)}</small>
                      {details.map((field) => (
                        <small title={field.value}>{field.label}: {field.value}</small>
                      ))}
                    </a>
                  );
                }) : <p>暂时还没有跌停股票。</p>}
              </div>
            </article>
          </div>

          {analysisExtraGroups.length > 0 && (
            <div class="analysis-grid analysis-grid-extra">
              {analysisExtraGroups.map((group) => (
                <article class="analysis-card">
                  <div class="analysis-card-head">
                    <h3>{group.label}</h3>
                  </div>
                  <div class="analysis-list">
                    {group.entries.map((entry) => (
                      <div class="analysis-row">
                        <span>{entry.title}</span>
                        {entry.fields.map((field) => (
                          <small title={field.value}>{field.label}: {field.value}</small>
                        ))}
                      </div>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>

        <footer class="market-foot">
          <span>行情可能有延迟，请以交易所和券商页面为准</span>
          <strong>{disclaimer}</strong>
        </footer>
      </main>
      <UiNewFooter />
    </div>
  </body>
</html>
