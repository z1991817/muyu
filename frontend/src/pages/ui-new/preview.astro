---
import { fetchHome } from "../../lib/api";
import { buildUiNewBoards, formatUiNewHeat, formatUiNewTime } from "../../lib/ui-new";
import type { HomeResponse } from "../../lib/types";

const fallbackHome: HomeResponse = {
  trends: [],
  markets: [],
  sources: [],
  calendar: {
    date: new Date().toISOString().slice(0, 10),
    isRestDay: false,
    kind: "workday",
    name: null,
  },
  stale: true,
  updatedAt: new Date().toISOString(),
};

const data = await fetchHome().catch(() => fallbackHome);
const boards = buildUiNewBoards(data);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>热搜聚合平台首页预览</title>
    <link rel="stylesheet" href="/ui-new/preview.css" />
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar">
        <div class="topbar-inner">
          <div class="brand">
            <span class="brand-mark">M</span>
          </div>

          <nav class="nav" aria-label="主导航">
            <a class="active" href="#">首页</a>
            <a href="#">关于</a>
          </nav>

          <div class="topbar-spacer"></div>

          <div class="theme-switcher">
            <label for="theme-select">主题</label>
            <select id="theme-select" aria-label="选择设计主题">
              <option value="notion">Notion</option>
              <option value="linear">Linear</option>
              <option value="vercel">Vercel</option>
              <option value="raycast">Raycast</option>
              <option value="intercom">Intercom</option>
              <option value="slack">Slack</option>
              <option value="bmw">BMW</option>
            </select>
          </div>
        </div>
      </header>

      <main>
        <section class="platform-grid" aria-label="各平台热搜">
          {boards.map((board) => (
            <article class="platform-card">
              <header class="platform-head">
                <div class="platform-title">
                  {board.iconUrl ? (
                    <img class="platform-icon" src={board.iconUrl} alt="" aria-hidden="true" />
                  ) : (
                    <span class="platform-icon" aria-hidden="true"></span>
                  )}
                  <h2>{board.platformName}</h2>
                </div>
                <button class="card-refresh" type="button" aria-label={`刷新${board.platformName}`}>
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M21 12a9 9 0 0 1-15.12 6.62M3 12A9 9 0 0 1 18.12 5.38M21 5v5h-5M3 19v-5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
              </header>
              <ol class="hot-list">
                {board.items.slice(0, 10).map((item, index) => {
                  const rank = item.rank || index + 1;
                  return (
                    <li class="hot-item">
                      <span class={`rank ${index < 3 ? "top" : ""}`}>{String(rank).padStart(2, "0")}</span>
                      <div class="hot-topic">
                        <a class="hot-title" href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                      </div>
                      <span class="heat">{formatUiNewHeat(item.heat, rank)}</span>
                    </li>
                  );
                })}
              </ol>
              <footer class="card-foot"><span>更新时间</span><strong>{formatUiNewTime(board.updatedAt)}</strong></footer>
            </article>
          ))}
        </section>
      </main>
    </div>
    <script is:inline>
      const themeSelect = document.querySelector("#theme-select");
      const savedTheme = localStorage.getItem("trend-theme") || "notion";

      function setTheme(theme) {
        document.documentElement.dataset.theme = theme === "notion" ? "" : theme;
        themeSelect.value = theme;
        localStorage.setItem("trend-theme", theme);
      }

      setTheme(savedTheme);
      themeSelect.addEventListener("change", (event) => setTheme(event.target.value));
    </script>
  </body>
</html>
