---
import BaseLayout from "../../components/BaseLayout.astro";
import HotBoard from "../../components/HotBoard.astro";
import TopBar from "../../components/TopBar.astro";
import { fetchTrends } from "../../lib/api";
import { PLATFORM_CLASS_MAP, PLATFORM_NAME_MAP } from "../../lib/platforms";

import "../../styles/global.css";

const platform = Astro.params.id ?? "weibo";
const data = await fetchTrends([platform]).catch(() => ({ items: [], stale: true, updatedAt: new Date().toISOString() }));
---

<BaseLayout title={`摸鱼热榜 | ${platform}`} description={`平台 ${platform} 热榜`} canonical={`https://example.com/source/${platform}`}>
  <main class="wrap">
    <TopBar stale={data.stale} updatedAt={data.updatedAt} />
    <section class="single">
      <HotBoard
        title={PLATFORM_NAME_MAP[platform] ?? platform}
        platformClass={PLATFORM_CLASS_MAP[platform] ?? "b-weibo"}
        items={data.items}
      />
    </section>
  </main>
</BaseLayout>

<style>
  .single {
    margin-top: 16px;
    max-width: 720px;
  }
</style>
