---
import BaseLayout from "../components/BaseLayout.astro";
import MainTopBar from "../components/MainTopBar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { fetchHome, fetchUsStocks } from "../lib/api";
import { getOffWorkStatus } from "../lib/offwork";
import { getProgrammerAlmanac } from "../lib/programmer-calendar";
import type { CalendarInfo, MarketStock, Trend } from "../lib/types";

import "../styles/global.css";

const fallbackCalendar: CalendarInfo = {
  date: new Date().toISOString().slice(0, 10),
  isRestDay: false,
  kind: "workday",
  name: null,
};

const [data, stocksData] = await Promise.all([
  fetchHome()
    .then((payload) => ({ ...payload, calendar: payload.calendar ?? fallbackCalendar }))
    .catch(() => ({
      trends: [],
      markets: [],
      sources: [],
      calendar: fallbackCalendar,
      stale: true,
      updatedAt: new Date().toISOString(),
    })),
  fetchUsStocks().catch(() => ({
    items: [] as MarketStock[],
    stale: true,
    updatedAt: new Date().toISOString(),
  })),
]);

const LAUNCH_DATE = new Date("2026-05-19T00:00:00+08:00");
const ISSUE_NO = Math.floor((Date.now() - LAUNCH_DATE.getTime()) / 86_400_000) + 1;

// 分组顺序：社交娱乐 → 资讯新闻 → 财经 → 科技开发 → 问答社区
const BOARD_ORDER: string[] = [
  "weibo", "douyin", "zhihu", "bilibili-hot-search", "baidu", "toutiao",
  "kuaishou", "hupu", "douban", "thepaper", "tieba", "36kr-renqi",
  "juejin", "github-trending-today", "ithome", "wallstreetcn-hot", "cls-hot", "jin10",
  "v2ex", "ifeng", "tencent-hot", "sspai", "coolapk", "gelonghui", "xueqiu-hotstock", "nowcoder",
];

type BoardMeta = {
  platform: string;
  className: string;
  icon: string;
  subline: string;
  tag: string;
  foot: string;
  sticker?: { label: string; style: string };
};

const BOARD_META: Record<string, BoardMeta> = {
  // 社交娱乐
  weibo: { platform: "weibo", className: "b-weibo", icon: "微", subline: "WEIBO · 实时", tag: "在翻滚", foot: "HOT · 持续翻滚", sticker: { label: "FRESH", style: "top:-12px;right:18px;background:var(--yellow);" } },
  douyin: { platform: "douyin", className: "b-douyin", icon: "抖", subline: "DOUYIN · 此刻", tag: "LIVE", foot: "FOR YOU · 沉浸黑洞" },
  kuaishou: { platform: "kuaishou", className: "b-kuaishou", icon: "快", subline: "KUAISHOU · 热榜", tag: "老铁", foot: "KWAI · 双击666" },
  "bilibili-hot-search": { platform: "bilibili-hot-search", className: "b-bili", icon: "B", subline: "B 站 · 全站", tag: "三连", foot: "三连预警", sticker: { label: "SUB!", style: "top:-10px;left:-10px;background:var(--pink);color:#fff;transform:rotate(-8deg);" } },
  douban: { platform: "douban", className: "b-douban", icon: "豆", subline: "DOUBAN · 文艺青年", tag: "小组", foot: "豆瓣 · 小组精选", sticker: { label: "小组", style: "top:-12px;right:18px;background:var(--ink);color:var(--paper);" } },
  hupu: { platform: "hupu", className: "b-hupu", icon: "H", subline: "HUPU · 步行街", tag: "BBS", foot: "STREET · 24H", sticker: { label: "BBS", style: "top:-12px;right:-10px;background:var(--green);color:#fff;transform:rotate(6deg);" } },
  // 资讯新闻
  toutiao: { platform: "toutiao", className: "b-toutiao", icon: "头", subline: "TOUTIAO · 推荐", tag: "算法推", foot: "今日头条 · 热榜" },
  baidu: { platform: "baidu", className: "b-baidu", icon: "百", subline: "BAIDU · 搜索", tag: "热搜", foot: "百度 · 热搜榜" },
  thepaper: { platform: "thepaper", className: "b-thepaper", icon: "澎", subline: "THEPAPER · 严肃", tag: "深度", foot: "澎湃 · 新闻纸" },
  ifeng: { platform: "ifeng", className: "b-ifeng", icon: "凤", subline: "IFENG · 资讯", tag: "凤凰", foot: "凤凰网 · 热点" },
  "tencent-hot": { platform: "tencent-hot", className: "b-tencent", icon: "腾", subline: "TENCENT · 早报", tag: "综合", foot: "腾讯新闻 · 早报" },
  // 财经
  "wallstreetcn-hot": { platform: "wallstreetcn-hot", className: "b-wsj", icon: "华", subline: "WALLST · 见闻", tag: "财经", foot: "华尔街见闻 · 热门", sticker: { label: "BULL", style: "top:-12px;right:18px;background:var(--green);color:#fff;" } },
  "cls-hot": { platform: "cls-hot", className: "b-cls", icon: "财", subline: "CLS · 快讯", tag: "快讯", foot: "财联社 · 热门" },
  jin10: { platform: "jin10", className: "b-jin10", icon: "金", subline: "JIN10 · 数据", tag: "数据", foot: "金十数据 · 热榜" },
  gelonghui: { platform: "gelonghui", className: "b-gelonghui", icon: "格", subline: "GLH · 研究", tag: "研报", foot: "格隆汇 · 热门" },
  "xueqiu-hotstock": { platform: "xueqiu-hotstock", className: "b-xueqiu", icon: "雪", subline: "XUEQIU · 热股", tag: "热股", foot: "雪球 · 热门股票" },
  // 科技开发
  "github-trending-today": { platform: "github-trending-today", className: "b-github", icon: "G", subline: "DAILY · 今日", tag: "技术宅", foot: "ALL LANGS · TODAY" },
  juejin: { platform: "juejin", className: "b-juejin", icon: "掘", subline: "JUEJIN · 开发者", tag: "掘金", foot: "稀土掘金 · 热榜" },
  sspai: { platform: "sspai", className: "b-sspai", icon: "少", subline: "SSPAI · 效率", tag: "效率", foot: "少数派 · 精选" },
  ithome: { platform: "ithome", className: "b-ithome", icon: "IT", subline: "ITHOME · 科技", tag: "科技", foot: "IT之家 · 热榜" },
  coolapk: { platform: "coolapk", className: "b-coolapk", icon: "酷", subline: "COOLAPK · 应用", tag: "安卓", foot: "酷安 · 热门" },
  nowcoder: { platform: "nowcoder", className: "b-nowcoder", icon: "牛", subline: "NOWCODER · 刷题", tag: "面试", foot: "牛客 · 讨论区" },
  // 问答社区
  zhihu: { platform: "zhihu", className: "b-zhihu", icon: "知", subline: "ZHIHU · 讨论中", tag: "谢邀", foot: "谢邀 · 人在工位" },
  tieba: { platform: "tieba", className: "b-tieba", icon: "贴", subline: "TIEBA · 神奇生物", tag: "古早味", foot: "BAIDU · TIEBA" },
  "36kr-renqi": { platform: "36kr-renqi", className: "b-36kr", icon: "氪", subline: "36KR · 人气", tag: "创业", foot: "36氪 · 人气榜" },
  v2ex: { platform: "v2ex", className: "b-v2ex", icon: "V", subline: "V2EX · 分享", tag: "new", foot: "V2EX · LATEST" },
};

const grouped = data.trends.reduce<Record<string, Trend[]>>((acc, item) => {
  const bucket = acc[item.platform] ?? [];
  bucket.push(item);
  acc[item.platform] = bucket;
  return acc;
}, {});

// 按固定顺序构建 boards，只包含有数据的平台
const boards = BOARD_ORDER
  .map((platform) => {
    const items = grouped[platform] ?? [];
    if (items.length === 0) return null;
    const meta = BOARD_META[platform];
    if (!meta) return null;
    return {
      platform,
      meta,
      items,
      platformName: items[0]?.platformName ?? platform,
      updatedAt: items[0]?.updatedAt ?? data.updatedAt,
    };
  })
  .filter((b): b is NonNullable<typeof b> => b !== null);

const staleText = data.stale ? "数据延迟" : "数据正常";
const now = new Date(data.updatedAt);
const nowDate = now.toLocaleDateString("zh-CN", {
  month: "2-digit",
  day: "2-digit",
});
const nowTime = now.toLocaleTimeString("zh-CN", {
  hour: "2-digit",
  minute: "2-digit",
  second: "2-digit",
  hour12: false,
});
const sourceCount = data.sources.length;
const warmingCount = data.trends.filter((item) => item.rank > 0 && item.rank <= 3).length;

const sortedMarkets = [...data.markets].sort((a, b) => {
  const order = ["DJI", "SPX", "IXIC"];
  const ai = order.indexOf(a.symbol);
  const bi = order.indexOf(b.symbol);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
const featuredMarkets = sortedMarkets.slice(0, 3);
const hotStocks = stocksData.items.slice(0, 10);
const indexTradeDate = featuredMarkets[0]?.tradeDate ?? "";
const stockTradeDate = hotStocks[0]?.tradeDate ?? "";
const marketStatus = data.markets[0]?.marketStatus ?? "closed";
const marketDisclaimer = data.markets[0]?.disclaimer ?? "仅供信息展示，不构成投资建议";

const marketStatusText = marketStatus === "open" ? "LIVE" : "CLOSED";
const marketStatusClass = marketStatus === "open" ? "open" : "closed";

function formatTimeLabel(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) {
    return "刚刚";
  }
  return d.toLocaleTimeString("zh-CN", {
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  });
}

function formatHeat(heat: string | undefined, rank: number): string {
  if (heat && heat.trim().length > 0) {
    return heat;
  }
  return `TOP ${rank}`;
}

function idxClassBySymbol(symbol: string): string {
  if (symbol === "DJI") {
    return "idx idx-dow";
  }
  if (symbol === "SPX") {
    return "idx idx-snp";
  }
  if (symbol === "IXIC") {
    return "idx idx-nas";
  }
  return "idx idx-dow";
}

function idxChineseName(symbol: string, fallbackName: string): string {
  if (symbol === "DJI") {
    return "道琼斯";
  }
  if (symbol === "SPX") {
    return "标普 500";
  }
  if (symbol === "IXIC") {
    return "纳斯达克";
  }
  return fallbackName;
}

function formatSigned(value: number): string {
  const abs = Math.abs(value).toFixed(2);
  return value >= 0 ? `+${abs}` : `-${abs}`;
}

function formatTradeDate(iso: string): string {
  if (!iso) return "";
  // iso = "YYYY-MM-DD"，转成 "2026年05月16日"
  const [y, m, d] = iso.split("-");
  if (!y || !m || !d) return iso;
  return `${y}年${m}月${d}日`;
}

function formatPriceParts(value: number): { whole: string; decimal: string } {
  const fixed = value.toFixed(2);
  const [whole, decimal] = fixed.split(".");
  return { whole, decimal };
}

const initialOffworkStatus = getOffWorkStatus(new Date(), data.calendar);
const initialOffworkCountdown = initialOffworkStatus.closed
  ? (initialOffworkStatus.reason === "after-hours" ? "下班了，好好休息 ♡" : "今天不上班 ♡")
  : initialOffworkStatus.countdown;

const almanac = getProgrammerAlmanac(new Date());
const restDayInfo = data.calendar;
const showRestDayCopy = restDayInfo.isRestDay || Astro.url.searchParams.get("holiday") === "1";
const mastTitle = showRestDayCopy
  ? { row1Text: "放慢脚步", highlight: "享受生活的", row2Text: "慢节奏~" }
  : { row1Text: "今天又是", highlight: "元气满满", row2Text: "的一天 ~" };

type SparkPoint = { x: number; y: number };

function buildSparkPoints(seed: string, trendUp: boolean): SparkPoint[] {
  let hash = 0;
  for (const ch of seed) {
    hash = (hash * 31 + ch.charCodeAt(0)) % 997;
  }
  const points: SparkPoint[] = [];
  const count = 10;
  for (let i = 0; i < count; i += 1) {
    const x = 2 + i * 12;
    const base = trendUp ? 22 - i * 1.6 : 8 + i * 1.6;
    const wobble = ((hash + i * 17) % 7) - 3;
    const y = Math.max(2, Math.min(26, base + wobble));
    points.push({ x, y });
  }
  return points;
}

function sparkPath(seed: string, trendUp: boolean): string {
  const points = buildSparkPoints(seed, trendUp);
  return points.map((p, idx) => `${idx === 0 ? "M" : "L"}${p.x} ${p.y}`).join(" " );
}

function idxAreaPath(seed: string, trendUp: boolean): string {
  const points = buildSparkPoints(seed, trendUp).map((p) => ({ x: p.x * 1.85, y: p.y + (trendUp ? 18 : 6) }));
  const line = points.map((p, idx) => `${idx === 0 ? "M" : "L"} ${p.x} ${p.y}`).join(" " );
  return `${line} L 218 54 L 2 54 Z`;
}

function idxLinePath(seed: string, trendUp: boolean): string {
  const points = buildSparkPoints(seed, trendUp).map((p) => ({ x: p.x * 1.85, y: p.y + (trendUp ? 18 : 6) }));
  return points.map((p, idx) => `${idx === 0 ? "M" : "L"} ${p.x} ${p.y}`).join(" " );
}
---

<BaseLayout title={`摸鱼热榜 / ${mastTitle.row1Text}${mastTitle.highlight}${mastTitle.row2Text.replace(" ~", "")}`} description="沿用《摸鱼热榜-趣味Riso风格设计规范》的首页，聚合公开热榜链接与美股概览。" canonical="https://example.com/">
<main class="wrap wide">

  <MainTopBar
    issueLabel={`摸鱼 ISSUE №${ISSUE_NO}`}
    navItems={[
      { href: "#boards-section", label: "热榜", active: true },
      { href: "/about", label: "关于我" },
    ]}
  >
    <Fragment slot="crumbs">
      <span><b>{nowDate}</b> 更新</span>
      <span>全站状态 · {staleText}</span>
      <span>同步时间 <b>{nowTime}</b></span>
      <span class="online-stat">摸鱼中 <b id="online-count">--</b> 人</span>
    </Fragment>
  </MainTopBar>

  <!-- MASTHEAD -->
  <section class="mast">
    <div>
      <h1 class="title">
        <span class="row1">{mastTitle.row1Text} <em>{mastTitle.highlight}</em></span>
        <span class="row2">{mastTitle.row2Text}</span>
        <svg class="squiggle" viewBox="0 0 340 34" fill="none">
          <path d="M2 22 C 30 4, 60 38, 90 18 S 150 -4, 180 18 S 240 36, 270 18 S 330 4, 338 18" stroke="#FF3D7F" stroke-width="4.5" stroke-linecap="round"/>
        </svg>
      </h1>
      <p class="lede">
        今天互联网又发生了很多事。微博、知乎、B 站、虎扑……
        全网 <b>{data.trends.length} 条</b>，帮你都盯着了，放心摸。
      </p>
    </div>

    <aside class="figureCard">
      <span class="tape"></span>
      <span class="badge">DAILY!</span>
      <h4>程序员黄历</h4>
      <p class="alm-date">{almanac.date} · {almanac.fortune}</p>
      <div class="alm-grid">
        <div class="alm-col alm-do">
          <span class="alm-label">宜</span>
          <ul>
            {almanac.dos.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="alm-col alm-dont">
          <span class="alm-label">忌</span>
          <ul>
            {almanac.donts.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
      <dl class="alm-meta">
        <div><dt>编程吉位</dt><dd>{almanac.luckyDir}</dd></div>
        <div><dt>编程凶位</dt><dd>{almanac.unluckyDir}</dd></div>
        <div><dt>幸运编辑器</dt><dd>{almanac.luckyEditor}</dd></div>
        <div><dt>幸运语言</dt><dd>{almanac.luckyLang}</dd></div>
      </dl>
    </aside>
  </section>

  <!-- TICKERS -->
  <section class="tickers">
    <div class="ticker">
      <div class="lab">全网热度</div>
      <div class="num">{data.trends.length.toLocaleString("zh-CN")}<small>条</small></div>
      <div class="delta up">LIVE · 持续更新</div>
      <svg viewBox="0 0 80 50"><polyline fill="none" stroke="#1F9F5F" stroke-width="3" points="2,40 14,32 26,36 38,18 50,24 62,8 78,14"/></svg>
    </div>
    <div class="ticker">
      <div class="lab">下班倒计时</div>
      <div class="num"><span id="offwork-countdown" data-calendar={JSON.stringify(data.calendar)}>{initialOffworkCountdown}</span><small></small></div>
      <div class="delta up">{restDayInfo.isRestDay ? `◎ ${restDayInfo.name ?? "休息日"}` : "18:00 下班"}</div>
      <svg viewBox="0 0 80 50"><circle cx="40" cy="25" r="18" fill="none" stroke="#2540D9" stroke-width="3"/><path d="M40 25 L 40 12" stroke="#2540D9" stroke-width="3" stroke-linecap="round"/><path d="M40 25 L 52 25" stroke="#FF3D7F" stroke-width="3" stroke-linecap="round"/></svg>
    </div>
    <div class="ticker">
      <div class="lab">正在升温</div>
      <div class="num">{warmingCount.toLocaleString("zh-CN")}<small>条</small></div>
      <div class="delta up">TOP 3 · 冒泡中</div>
      <svg viewBox="0 0 80 50"><path d="M2 40 L 12 18 L 22 30 L 32 12 L 44 26 L 56 8 L 70 22 L 78 14" fill="none" stroke="#FF3D7F" stroke-width="3"/></svg>
    </div>
    <div class="ticker">
      <div class="lab">信号来源</div>
      <div class="num">{sourceCount}<small>源</small></div>
      <div class="delta up">公开榜单 · 持续接入</div>
      <svg viewBox="0 0 80 50">
        <rect x="6" y="14" width="14" height="22" fill="none" stroke="#1A1714" stroke-width="2.5" rx="3"/>
        <rect x="26" y="6" width="14" height="36" fill="none" stroke="#1A1714" stroke-width="2.5" rx="3"/>
        <rect x="46" y="20" width="14" height="20" fill="none" stroke="#1A1714" stroke-width="2.5" rx="3"/>
        <rect x="66" y="10" width="10" height="30" fill="none" stroke="#1A1714" stroke-width="2.5" rx="3"/>
      </svg>
    </div>
  </section>

  <!-- BOARDS -->
  <section class="boards" id="boards-section">

    {boards.map((board) => (
      <article class={`board ${board.meta.className}`} data-platform={board.platform} data-platform-name={board.platformName}>
        {board.meta.sticker ? (
          <span class="sticker" style={board.meta.sticker.style}>{board.meta.sticker.label}</span>
        ) : null}
        <div class="b-head">
          <div class="b-icon">{board.meta.icon}</div>
          <div>
            <div class="b-name">{board.platformName}</div>
            <div class="b-sub">{board.meta.subline}</div>
          </div>
          <div class="b-actions">
            <button class="b-btn b-refresh" type="button" title="刷新" aria-label="刷新">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 8a6 6 0 1 1 -1.76 -4.24"/>
                <path d="M14 2v4h-4"/>
              </svg>
            </button>
            <button class="b-btn b-expand" type="button" title="放大查看" aria-label="放大查看">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 2h4v4M6 14H2v-4M14 2l-5 5M2 14l5-5"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="b-meta">更新 {formatTimeLabel(board.updatedAt)} · 在榜 {board.items.length} 条</div>
        <ol class="b-list">
          {board.items.map((item, idx) => (
            <li class={idx === 0 ? "top1" : idx === 1 ? "top2" : idx === 2 ? "top3" : ""}>
              <a href={item.url} target="_blank" rel="noopener noreferrer">
                <span class="rk">{String(item.rank ?? idx + 1).padStart(2, "0")}</span>
                <span class="ttl">{idx === 0 ? <b>{item.title}</b> : item.title}</span>
                <span class="heat">{formatHeat(item.heat, item.rank ?? idx + 1)}</span>
              </a>
            </li>
          ))}
        </ol>
        <div class="b-foot"><span>{board.meta.foot}</span></div>
      </article>
    ))}

  </section>
    <!-- US STOCKS WIDGET · 盘中偷瞄 -->
  <section class="stocks">
    <header class="stocks-head">
      <span class="stocks-stamp">NYSE 偷瞄</span>
      <div class="stocks-title">
        <h3>美股今日大盘 <em>{marketStatus === "open" ? "BULL ?" : "SNOOZE"}</em></h3>
        <p>
          {indexTradeDate ? <span class="trade-date">AS OF {formatTradeDate(indexTradeDate)}</span> : null}
          {" "}延迟行情，不作为投资参考。
        </p>
      </div>
      <div class={`stocks-status ${marketStatusClass}`}>
        <span class="dot"></span><b>{marketStatusText}</b> · {nowTime}
      </div>
    </header>

    {featuredMarkets.length > 0 ? (
      <div class="stocks-indices">
        {featuredMarkets.map((item) => {
          const up = item.change >= 0;
          const price = formatPriceParts(item.price);
          const gradId = `gd-${item.symbol.toLowerCase()}`;
          const line = idxLinePath(item.symbol, up);
          const area = idxAreaPath(item.symbol, up);
          const last = line.split("L").at(-1)?.trim().split(" ") ?? ["218", "8"];
          const cx = Number(last[0]);
          const cy = Number(last[1]);
          return (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class={`idx-link ${idxClassBySymbol(item.symbol)}`}>
              <span class="sticker-tag">{item.symbol}</span>
              <div class="idx-name">{idxChineseName(item.symbol, item.name)} <em>{item.name}</em></div>
              <div class="idx-val">{price.whole}<small>.{price.decimal}</small></div>
              <div class={`idx-delta ${up ? "up" : "down"}`}>
                {up ? "▲" : "▼"} {formatSigned(item.change)} &nbsp;({formatSigned(item.changePct)}%)
              </div>
              <svg class="idx-spark" viewBox="0 0 220 54" preserveAspectRatio="none" fill="none">
                <defs>
                  <linearGradient id={gradId} x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0" stop-color={up ? "#1F9F5F" : "#FF3D7F"} stop-opacity={up ? ".35" : ".30"}/>
                    <stop offset="1" stop-color={up ? "#1F9F5F" : "#FF3D7F"} stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d={area} fill={`url(#${gradId})`} />
                <path d={line} stroke={up ? "#1F9F5F" : "#FF3D7F"} stroke-width="2.4" stroke-linejoin="round" stroke-linecap="round" />
                <circle cx={cx} cy={cy} r="3.4" fill="#FFF4D6" stroke={up ? "#1F9F5F" : "#FF3D7F"} stroke-width="2"/>
              </svg>
              <div class="idx-foot"><span>{up ? "MOVE UP" : "MOVE DOWN"}</span><span>{formatTimeLabel(item.updatedAt)}</span></div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="idx-empty">暂时没有拉到指数数据，稍后会自动刷新。</div>
    )}

    <div class="stocks-list-head">
      <h4>热门个股 <em>· Hot Stocks{stockTradeDate ? ` · AS OF ${formatTradeDate(stockTradeDate)}` : ""}</em></h4>
      <span class="rule"></span>
      <span class="legend">▲ <b class="u">绿涨</b> &nbsp; ▼ <b class="d">粉跌</b> &nbsp;·&nbsp; 延迟行情</span>
    </div>

    {hotStocks.length > 0 ? (
      <div class="stocks-list">
        {hotStocks.map((item) => {
          const up = item.changePct >= 0;
          const spark = sparkPath(item.symbol, up);
          return (
            <a class={`stk ${up ? "up" : "down"}`} href={item.url} target="_blank" rel="noopener noreferrer">
              <div class="stk-row1"><span class="tic">{item.symbol}</span><span class="cn">{item.name}</span></div>
              <div class="stk-row2"><span class="px">$ {item.price.toFixed(2)}</span><span class="ch">{formatSigned(item.changePct)}%</span></div>
              <svg class="stk-spark" viewBox="0 0 120 28" preserveAspectRatio="none" fill="none"><path d={spark} stroke={up ? "#1F9F5F" : "#FF3D7F"} stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/></svg>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="stocks-empty"><p>个股行情接口当前返回空列表，保留模块样式并等待后端数据恢复。</p></div>
    )}

    <div class="stocks-foot">
      <span>DELAYED 15 MIN · 仅供工位偷瞄 · {marketDisclaimer}</span>
    </div>
  </section>

  <!-- FOOTER ROW -->
  <section class="footer" id="about-me">
    <div class="colophon">
      <h5>关于摸鱼热榜</h5>
      <p>纸短情长，{sourceCount} 处热榜尽收其中。片纸之上，人间冷暖皆有回响。</p>
      <div class="credits">
        UPDATED · {nowTime} &nbsp;·&nbsp; {sourceCount} SOURCES &nbsp;·&nbsp; PRINTED ON CREAM #FFF4D6 &nbsp;·&nbsp; v1.0
      </div>
    </div>

    <div class="quote">
      "上班八小时<br/>摸鱼七小时半<br/>剩下半小时<br/>用来想下一次摸鱼。"
      <span>— 工位哲学家 · 第 {ISSUE_NO} 期</span>
    </div>

    <div class="stickers-grid">
      <div class="doodlecard tag1">
        <h6>🪄 摸鱼小技巧</h6>
        <p>把屏幕分两半，左边 IDE 假装在写代码，右边热榜——只要 Alt+Tab 够快，老板永远在你的盲区。</p>
      </div>
      <div class="doodlecard tag2">
        <h6>⚠️ 免责声明</h6>
        <p>本站内容仅供摸鱼参考，不构成投资建议，不构成请假理由，不对因过度沉迷导致的绩效下滑负责。</p>
      </div>
    </div>
  </section>

  <!-- TOAST -->
  <div class="toast-stack" id="toast-stack"></div>

  <!-- EXPAND MODAL -->
  <div class="modal-backdrop" id="expand-modal" role="dialog" aria-modal="true" aria-label="热搜详情">
    <div class="modal-card" id="expand-modal-card">
      <button class="modal-close" id="expand-modal-close" aria-label="关闭">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M2 2l12 12M14 2L2 14"/>
        </svg>
      </button>
      <div class="modal-head" id="expand-modal-head"></div>
      <div class="modal-meta" id="expand-modal-meta"></div>
      <ol class="modal-list" id="expand-modal-list"></ol>
      <div class="modal-foot" id="expand-modal-foot"></div>
    </div>
  </div>

  <SiteFooter />

  <!-- BACK TO TOP -->
  <button id="back-to-top" aria-label="返回顶部" title="返回顶部">
    <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 13V3M3 8l5-5 5 5"/>
    </svg>
    <span>TOP</span>
  </button>
</main>
</BaseLayout>

<style is:global>
:root{
    --paper:#FFF4D6;
    --paper-deep:#FFE9A8;
    --ink:#1A1714;
    --pink:#FF3D7F;
    --pink-soft:#FFD6E2;
    --blue:#2540D9;
    --blue-soft:#CFD8FF;
    --yellow:#FFC93C;
    --green:#1F9F5F;
    --green-soft:#C8F3D9;
    --orange:#FF6B2C;
    --lilac:#B080FF;
  }

  *{box-sizing:border-box;margin:0;padding:0}
  html,body{background:var(--paper);color:var(--ink);font-family:"Space Mono","Helvetica Neue",sans-serif;}

  /* paper grain */
  body{
    min-height:100vh;
    background-image:
      radial-gradient(circle at 22% 18%, rgba(255,61,127,.10) 0, transparent 38%),
      radial-gradient(circle at 82% 8%,  rgba(37,64,217,.10) 0, transparent 40%),
      radial-gradient(circle at 92% 88%, rgba(255,201,60,.18) 0, transparent 45%),
      radial-gradient(circle at 8% 92%,  rgba(31,159,95,.10) 0, transparent 40%);
    background-color:var(--paper);
  }
  body::before{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:1;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.92' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.10 0 0 0 0 0.09 0 0 0 0 0.08 0 0 0 0.55 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.18'/></svg>");
    mix-blend-mode:multiply;opacity:.55;
  }
  /* halftone overlay */
  body::after{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:0;
    background-image:radial-gradient(circle at center, var(--ink) 0.6px, transparent 1.1px);
    background-size:7px 7px;opacity:.05;
  }

  .wrap{max-width:1380px;margin:0 auto;padding:28px 36px 80px;position:relative;z-index:2;}

  .online-stat{
    display:inline-flex;align-items:center;gap:5px;
    background:var(--ink);color:var(--paper);
    font-family:"Bagel Fat One",sans-serif;font-size:11px;letter-spacing:.12em;
    padding:2px 10px 3px;border-radius:999px;
    transform:rotate(1deg);
  }
  .online-stat::before{
    content:"";display:inline-block;width:6px;height:6px;border-radius:50%;
    background:var(--green);flex-shrink:0;
  }

  /* --- masthead --- */
  .mast{
    margin-top:32px;display:grid;grid-template-columns:1.55fr .9fr;gap:28px;align-items:end;
