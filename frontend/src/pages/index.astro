  @keyframes spin{to{transform:rotate(360deg);}}

  /* toast */
  .toast-stack{
    position:fixed;top:24px;left:50%;transform:translateX(-50%);
    z-index:100;display:flex;flex-direction:column;gap:8px;pointer-events:none;
  }
  .toast{
    font-family:"ZCOOL KuaiLe",sans-serif;font-size:14px;
    background:var(--ink);color:var(--paper);
    border:2.5px solid var(--ink);border-radius:10px;
    padding:8px 16px;box-shadow:4px 4px 0 var(--pink);
    transform:translateY(-12px) rotate(-1.2deg);opacity:0;
    transition:transform .25s cubic-bezier(.2,.7,.2,1),opacity .25s;
  }
  .toast.show{transform:translateY(0) rotate(-1.2deg);opacity:1;}
