---
import UiNewSeo from "../components/ui-new/UiNewSeo.astro";
import UiNewFooter from "../components/ui-new/UiNewFooter.astro";
import UiNewTopBar from "../components/ui-new/UiNewTopBar.astro";
import { fetchHome } from "../lib/api";
import { SITE_KEYWORDS, SITE_NAME, SITE_URL } from "../lib/seo";
import { buildUiNewBoards, formatUiNewTime, groupUiNewBoards } from "../lib/ui-new";
import type { HomeResponse } from "../lib/types";

const fallbackHome: HomeResponse = {
  trends: [],
  markets: [],
  sources: [],
  calendar: {
    date: new Date().toISOString().slice(0, 10),
    isRestDay: false,
    kind: "workday",
    name: null,
  },
  stale: true,
  updatedAt: new Date().toISOString(),
};

const data = await fetchHome().catch(() => fallbackHome);
const boards = buildUiNewBoards(data);
const boardGroups = groupUiNewBoards(boards);
const hasBoards = boardGroups.length > 0;
const clientApiBase = import.meta.env.DEV ? "http://127.0.0.1:8000/api" : "/api";
const pageTitle = "摸鱼热榜 - 微博知乎B站抖音热搜聚合";
const pageDescription =
  "摸鱼热榜聚合微博、知乎、B站、抖音、虎扑、百度、GitHub、V2EX 等公开热榜，帮你快速扫一眼今天大家在聊什么。";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  url: SITE_URL,
  description: pageDescription,
  keywords: SITE_KEYWORDS,
  inLanguage: "zh-CN",
  isPartOf: {
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
  },
  about: ["热搜平台", "热搜聚合", "今日热搜", "微博热搜", "知乎热榜", "B站热搜"],
  hasPart: boards.slice(0, 12).map((board) => ({
    "@type": "ItemList",
    name: `${board.platformName}热榜`,
    numberOfItems: board.items.length,
    itemListElement: board.items.slice(0, 10).map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      url: item.url,
    })),
  })),
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <UiNewSeo title={pageTitle} description={pageDescription} canonical="/" structuredData={structuredData} />
    <script is:inline>
      (() => {
        try {
          if (localStorage.getItem("moyu-ui-version") === "bold") {
            window.location.replace("/bold");
            return;
          }
          const savedSkin = localStorage.getItem("trend-skin") || "dim";
          document.documentElement.dataset.skin = savedSkin === "dim" ? "dim" : "";
        } catch {
          document.documentElement.dataset.skin = "dim";
        }
      })();
    </script>
    <link rel="stylesheet" href="/ui-new/base.css" />
    <link rel="stylesheet" href="/ui-new/preview.css" />
  </head>
  <body>
    <div class="app-shell" data-api-base={clientApiBase}>
      <UiNewTopBar active="home" />
      <aside class="skin-switch-note" aria-label="界面版本提示">
        <span>本站 UI 已修改为简约版。</span>
        <a href="/bold" data-ui-version="bold">如果您还是喜欢以前的 UI，可以切换到大胆版。</a>
      </aside>

      <main>
        {hasBoards ? (
          <div class="category-stack">
            <h1 class="sr-only">摸鱼热榜 - 微博知乎B站抖音热搜聚合</h1>
            {boardGroups.map((group) => (
              <section class="category-section" data-category={group.id} aria-labelledby={`category-${group.id}`}>
                <header class="category-head">
                  <div>
                    <h2 id={`category-${group.id}`}>{group.label}</h2>
                  </div>
                </header>
                <div class="platform-grid">
                  {group.boards.map((board) => (
                    <article class="platform-card" data-platform={board.platform} data-platform-name={board.platformName}>
                      <header class="platform-head">
                        <div class="platform-title">
                          {board.iconUrl ? (
                            <img class="platform-icon" src={board.iconUrl} alt="" aria-hidden="true" />
                          ) : (
                            <span class="platform-icon" aria-hidden="true"></span>
                          )}
                          <h3>{board.platformName}</h3>
                        </div>
                        <button class="card-refresh" type="button" aria-label={`刷新${board.platformName}`}>
                          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M15.75 6.75A6.5 6.5 0 1 0 16 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                            <path d="M15.75 3.75v3h-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </button>
                      </header>
                      <ol class="hot-list">
                        {board.items.map((item, index) => {
                          const rank = item.rank || index + 1;
                          return (
                            <li class="hot-item">
                              <span class={`rank ${index < 3 ? "top" : ""}`}>{String(rank).padStart(2, "0")}</span>
                              <div class="hot-topic">
                                <a class="hot-title" href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                              </div>
                            </li>
                          );
                        })}
                      </ol>
                      <footer class="card-foot"><span>更新时间</span><strong data-updated-at>{formatUiNewTime(board.updatedAt)}</strong></footer>
                    </article>
                  ))}
                </div>
              </section>
            ))}
          </div>
        ) : (
          <section class="empty-state" aria-labelledby="empty-title">
            <p class="empty-kicker">NO DATA</p>
            <h1 id="empty-title">热榜数据暂时没有返回</h1>
            <p>页面结构已经加载，但本地 API 服务当前不可用或没有返回热榜内容。启动后端后刷新页面即可看到平台列表。</p>
          </section>
        )}
      </main>
      <UiNewFooter />
      <div class="toast-host" aria-live="polite" aria-atomic="true"></div>
    </div>
    <script is:inline>
      const API_BASE = document.querySelector(".app-shell")?.dataset.apiBase || "/api";

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function formatTime(iso) {
        const date = new Date(iso);
        if (Number.isNaN(date.getTime())) return "--:--";
        return date.toLocaleTimeString("zh-CN", {
          hour: "2-digit",
          minute: "2-digit",
          hour12: false,
        });
      }

      function renderItems(items) {
        return items
          .map((item, index) => {
            const rank = item.rank || index + 1;
            const rankClass = index < 3 ? "rank top" : "rank";
            return `
              <li class="hot-item">
                <span class="${rankClass}">${String(rank).padStart(2, "0")}</span>
                <div class="hot-topic">
                  <a class="hot-title" href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer">${escapeHtml(item.title)}</a>
                </div>
              </li>
            `;
          })
          .join("");
      }

      function showToast(message, type = "ok") {
        const host = document.querySelector(".toast-host");
        if (!host) return;
        const toast = document.createElement("div");
        toast.className = `toast ${type === "error" ? "is-error" : ""}`;
        toast.textContent = message;
        host.append(toast);
        requestAnimationFrame(() => toast.classList.add("is-visible"));
        window.setTimeout(() => {
          toast.classList.remove("is-visible");
          toast.addEventListener("transitionend", () => toast.remove(), { once: true });
        }, 2200);
      }

      async function refreshCard(card) {
        const platform = card.dataset.platform;
        if (!platform || card.classList.contains("is-refreshing")) return;

        const button = card.querySelector(".card-refresh");
        const list = card.querySelector(".hot-list");
        const updatedAt = card.querySelector("[data-updated-at]");
        const platformName = card.dataset.platformName || "热榜";
        if (!button || !list) return;

        card.classList.add("is-refreshing");
        button.disabled = true;

        try {
          const response = await fetch(`${API_BASE}/trends?platform=${encodeURIComponent(platform)}&refresh=true`);
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const payload = await response.json();
          const items = payload.items || [];
          list.innerHTML = renderItems(items);
          list.scrollTop = 0;
          if (updatedAt) updatedAt.textContent = formatTime(payload.updatedAt);
          showToast(`${platformName} 已刷新 · ${items.length} 条`);
        } catch (error) {
          console.error("refresh failed", error);
          showToast(`${platformName} 刷新失败`, "error");
        } finally {
          card.classList.remove("is-refreshing");
          button.disabled = false;
        }
      }

      document.querySelectorAll(".platform-card").forEach((card) => {
        card.querySelector(".card-refresh")?.addEventListener("click", () => refreshCard(card));
      });

      document.querySelectorAll("[data-ui-version]").forEach((link) => {
        link.addEventListener("click", () => {
          const version = link.dataset.uiVersion;
          if (version) localStorage.setItem("moyu-ui-version", version);
        });
      });
    </script>
  </body>
</html>
