</style>

<script>
  import { getOffWorkStatus } from "../lib/offwork";

  const countdownNode = document.getElementById('offwork-countdown');

  function tickOffworkCountdown() {
    if (!countdownNode) return;
    const calendar = JSON.parse(countdownNode.dataset.calendar ?? '{"isRestDay":false,"kind":"workday"}');
    const status = getOffWorkStatus(new Date(), calendar);
    countdownNode.textContent = status.closed
      ? (status.reason === 'after-hours' ? '下班了，好好休息 ♡' : '今天不上班 ♡')
      : (status.countdown ?? '--:--:--');
  }

  tickOffworkCountdown();
  setInterval(tickOffworkCountdown, 1000);

  // ---- toast ----
  const toastStack = document.getElementById('toast-stack');
  function showToast(msg: string, kind: 'ok' | 'err' = 'ok') {
    if (!toastStack) return;
    const el = document.createElement('div');
    el.className = `toast ${kind}`;
    el.textContent = msg;
    toastStack.appendChild(el);
    requestAnimationFrame(() => el.classList.add('show'));
    setTimeout(() => {
      el.classList.remove('show');
      setTimeout(() => el.remove(), 260);
    }, 1800);
  }

  // ---- board refresh ----
  const API_BASE = import.meta.env.DEV ? 'http://127.0.0.1:8000/api' : '/api';

  type TrendItem = { platform: string; platformName: string; title: string; url: string; rank: number; heat: string; updatedAt: string };

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  function formatHeatJs(heat: string | undefined, rank: number): string {
    return heat && heat.trim().length > 0 ? heat : `TOP ${rank}`;
  }

  function renderListItems(items: TrendItem[]): string {
    return items.map((item, idx) => {
      const cls = idx === 0 ? 'top1' : idx === 1 ? 'top2' : idx === 2 ? 'top3' : '';
      const rank = String(item.rank ?? idx + 1).padStart(2, '0');
      const ttl = idx === 0 ? `<b>${escapeHtml(item.title)}</b>` : escapeHtml(item.title);
      return `<li class="${cls}"><a href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer"><span class="rk">${rank}</span><span class="ttl">${ttl}</span><span class="heat">${escapeHtml(formatHeatJs(item.heat, item.rank ?? idx + 1))}</span></a></li>`;
    }).join('');
  }

  // ---- expand modal ----
  const expandModal = document.getElementById('expand-modal')!;
  const expandModalClose = document.getElementById('expand-modal-close')!;
  const expandModalHead = document.getElementById('expand-modal-head')!;
  const expandModalMeta = document.getElementById('expand-modal-meta')!;
  const expandModalList = document.getElementById('expand-modal-list')!;
  const expandModalFoot = document.getElementById('expand-modal-foot')!;

  function openExpandModal(boardEl: HTMLElement) {
    const platform = boardEl.dataset.platform ?? '';
    const platformName = boardEl.dataset.platformName ?? platform;
    const iconEl = boardEl.querySelector<HTMLElement>('.b-icon');
    const nameEl = boardEl.querySelector<HTMLElement>('.b-name');
    const subEl = boardEl.querySelector<HTMLElement>('.b-sub');
    const metaEl = boardEl.querySelector<HTMLElement>('.b-meta');
    const footEl = boardEl.querySelector<HTMLElement>('.b-foot');
    const listEl = boardEl.querySelector<HTMLOListElement>('.b-list');

    // 复制 icon 样式（背景色）
    const iconStyle = iconEl ? iconEl.getAttribute('style') ?? '' : '';
    const iconClass = iconEl ? Array.from(iconEl.classList).join(' ') : 'b-icon';
    expandModalHead.innerHTML = `
      <div class="m-icon ${iconClass}" style="${iconStyle}">${iconEl?.textContent ?? ''}</div>
      <div>
        <div class="m-name">${escapeHtml(nameEl?.textContent ?? platformName)}</div>
        <div class="m-sub">${escapeHtml(subEl?.textContent ?? '')}</div>
      </div>`;

    expandModalMeta.textContent = metaEl?.textContent ?? '';
    expandModalList.innerHTML = listEl?.innerHTML ?? '';
    expandModalFoot.textContent = footEl?.querySelector('span')?.textContent ?? '';

    expandModal.classList.add('open');
    document.body.style.overflow = 'hidden';
    expandModalClose.focus();
  }

  function closeExpandModal() {
    expandModal.classList.remove('open');
    document.body.style.overflow = '';
  }

  expandModalClose.addEventListener('click', closeExpandModal);
  expandModal.addEventListener('click', (ev) => {
    if (ev.target === expandModal) closeExpandModal();
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape' && expandModal.classList.contains('open')) closeExpandModal();
  });

  async function refreshBoard(boardEl: HTMLElement) {
    const platform = boardEl.dataset.platform;
    if (!platform) return;
    const btn = boardEl.querySelector<HTMLButtonElement>('.b-refresh');
    const list = boardEl.querySelector<HTMLOListElement>('.b-list');
    const meta = boardEl.querySelector<HTMLDivElement>('.b-meta');
    if (!btn || !list) return;
    if (btn.classList.contains('is-loading')) return;
    btn.classList.add('is-loading');
    btn.disabled = true;
    try {
      const res = await fetch(`${API_BASE}/trends?platform=${encodeURIComponent(platform)}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json() as { items: TrendItem[]; updatedAt: string };
      const items = data.items ?? [];
      list.innerHTML = renderListItems(items);
      if (meta) {
        const t = new Date(data.updatedAt);
        const tt = isNaN(t.getTime()) ? '刚刚' : t.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', hour12: false });
        meta.textContent = `更新 ${tt} · 在榜 ${items.length} 条`;
      }
      boardEl.dataset.items = JSON.stringify(items);
      const name = boardEl.dataset.platformName ?? '热榜';
      showToast(`✓ ${name} 已刷新 · ${items.length} 条`, 'ok');
    } catch (e) {
      console.error('refresh failed', e);
      showToast('刷新失败，稍后再试', 'err');
    } finally {
      btn.classList.remove('is-loading');
      btn.disabled = false;
    }
  }

  document.querySelectorAll<HTMLElement>('.board').forEach((board) => {
    board.querySelector('.b-refresh')?.addEventListener('click', (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      refreshBoard(board);
    });
    board.querySelector('.b-expand')?.addEventListener('click', (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      openExpandModal(board);
    });
  });

  // ---- umami 在线人数 ----
  const onlineCountNode = document.getElementById('online-count');
  const UMAMI_SITE_ID = (import.meta.env.PUBLIC_UMAMI_SITE_ID as string | undefined) ?? '';
  const UMAMI_API_BASE = (import.meta.env.PUBLIC_UMAMI_API_BASE as string | undefined) ?? 'https://api.umami.is';
  const UMAMI_API_KEY = (import.meta.env.PUBLIC_UMAMI_API_KEY as string | undefined) ?? '';

  async function fetchOnlineCount() {
    if (!onlineCountNode || !UMAMI_SITE_ID || !UMAMI_API_KEY) return;
    try {
      const res = await fetch(`${UMAMI_API_BASE}/api/websites/${UMAMI_SITE_ID}/active`, {
        headers: { 'x-umami-api-key': UMAMI_API_KEY },
      });
      if (!res.ok) return;
      const json = await res.json() as { x: number } | { visitors: number };
      // Umami v2 返回 { x: number }，Cloud 版可能返回 { visitors: number }
      const count = 'x' in json ? json.x : (json as { visitors: number }).visitors;
      onlineCountNode.textContent = String(count ?? '--');
    } catch {
      // 静默失败，保持 "--"
    }
  }

  fetchOnlineCount();
  setInterval(fetchOnlineCount, 30_000);

  // ---- back to top ----
  const backToTop = document.getElementById('back-to-top');
  if (backToTop) {
    window.addEventListener('scroll', () => {
      backToTop.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
