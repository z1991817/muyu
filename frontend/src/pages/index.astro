  .b-head{display:flex;align-items:center;gap:10px;}
  .b-icon{
    width:40px;height:40px;border-radius:12px;border:2px solid var(--ink);
    display:grid;place-items:center;font-family:"Bagel Fat One",sans-serif;font-size:18px;
    box-shadow:3px 3px 0 var(--ink);flex-shrink:0;
  }
  .b-name{font-family:"ZCOOL KuaiLe",sans-serif;font-size:22px;line-height:1;}
