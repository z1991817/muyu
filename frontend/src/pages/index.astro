  .ticker:nth-child(4){background:#FFE6BD;transform:rotate(1deg);}
  .ticker .lab{font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#4a423a}
  .ticker .num{font-family:"Bagel Fat One",sans-serif;font-size:36px;line-height:1.05;margin-top:6px;}
  .ticker .num small{font-size:14px;font-family:"Space Mono";color:#5a5147;margin-left:4px;}
  .ticker .delta{font-size:10px;margin-top:8px;letter-spacing:.1em;text-transform:uppercase;font-family:"Space Mono",monospace;display:inline-flex;align-items:center;gap:5px;padding:2px 9px 3px;border-radius:999px;border:1.5px solid currentColor;width:fit-content;}
  .ticker:nth-child(1) .delta{color:var(--green);}
  .ticker:nth-child(2) .delta{color:var(--blue);}
  .ticker:nth-child(3) .delta{color:var(--pink);}
  .ticker:nth-child(4) .delta{color:var(--orange);}
  .ticker .delta.down{color:var(--pink);}
  .ticker svg{position:absolute;right:-6px;bottom:-8px;width:90px;opacity:.85}

  /* --- BOARDS GRID --- */
  .boards{
    margin-top:38px;
