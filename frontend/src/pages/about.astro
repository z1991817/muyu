---
import "../styles/global.css";
import BaseLayout from "../components/BaseLayout.astro";
import MainTopBar from "../components/MainTopBar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { absoluteUrl, SITE_NAME, SITE_URL } from "../lib/seo";

const LAUNCH_DATE = new Date("2026-05-19T00:00:00+08:00");
const ISSUE_NO = Math.floor((Date.now() - LAUNCH_DATE.getTime()) / 86_400_000) + 1;
const siteHost = new URL(SITE_URL).hostname;
const updatedAt = new Date().toISOString();
const updatedDate = new Date(updatedAt).toLocaleDateString("zh-CN", {
  month: "2-digit",
  day: "2-digit",
});
const updatedTime = new Date(updatedAt).toLocaleTimeString("zh-CN", {
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
});

const pageTitle = "关于摸鱼热榜 - 公开热榜链接聚合器说明";
const pageDescription =
  "了解摸鱼热榜的来处、数据边界与版权声明。本站只聚合公开热榜标题、热度、排名和原站链接，不抓取正文、不做摘要。";
const aboutStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: pageTitle,
    url: absoluteUrl("/about"),
    description: pageDescription,
    inLanguage: "zh-CN",
    isPartOf: {
      "@type": "WebSite",
      name: SITE_NAME,
      url: SITE_URL,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "首页",
        item: SITE_URL,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "关于摸鱼热榜",
        item: absoluteUrl("/about"),
      },
    ],
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical="/about" structuredData={aboutStructuredData}>
  <main>
    <div class="wrap">

        <!-- 顶栏 -->
        <MainTopBar
          issueLabel={`摸鱼 ISSUE №${ISSUE_NO}`}
          navItems={[
            { href: "/", label: "热榜" },
            { href: "/about", label: "关于我", active: true },
          ]}
        >
          <Fragment slot="crumbs">
            <span><b>{updatedDate}</b> 更新</span>
            <span>站长档案 · 小站说明</span>
            <span>同步时间 <b>{updatedTime}</b></span>
          </Fragment>
        </MainTopBar>

        <!-- Hero -->
        <section class="hero">
          <div class="hero-left">
            <div class="hero-title-wrap">
              <h1 class="hero-title">关于本鱼</h1>
              <svg class="squiggle" viewBox="0 0 320 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M2 9 C22 2, 42 16, 62 9 S102 2, 122 9 S162 16, 182 9 S222 2, 242 9 S282 16, 302 9 S318 4, 318 9" stroke="var(--pink)" stroke-width="4.5" stroke-linecap="round" fill="none"/>
              </svg>
            </div>
            <p class="hero-lede">把每天都要打开的热榜，收进一个少点打扰的页面。</p>
            <p class="hero-sub">上班要认真，摸鱼也要讲究一点秩序感。</p>
          </div>
          <div class="hero-right">
            <div class="tape tape-top"></div>
            <div class="namecard">
              <div class="namecard-role">前端工程师 · 小工具爱好者</div>
              <div class="namecard-divider"></div>
              <div class="namecard-site">摸鱼热榜</div>
              <div class="namecard-url">{siteHost}</div>
              <div class="namecard-stamp">SINCE<br/>2026</div>
            </div>
          </div>
        </section>

        <!-- 工位档案 -->
        <section class="profile-section">
          <div class="section-label">工位档案 · 第 001 号</div>
          <div class="profile-grid">
            <div class="profile-text">
              <p>白天写业务，晚上修自己的小玩具。摸鱼热榜不是宏大项目，只是我刷热榜时被来回切 App 折腾烦了，顺手把它做成一个能用的小站。</p>
              <p>我喜欢这种小而具体的东西：打开就有答案，点一下就回到原站，不替你下结论，也不把注意力再卖一遍。</p>
              <p>如果你也在做小工具，或者发现这里哪里不好用，欢迎来聊。好想法不用憋着，憋久了容易变成收藏夹里的灰。</p>
            </div>
            <div class="skills-note">
              <div class="skills-note-title">随身工具箱</div>
              <div class="skills-note-divider"></div>
              <ul class="skills-list">
                <li>HTML / CSS</li>
                <li>JavaScript</li>
                <li>TypeScript</li>
                <li>Astro</li>
                <li>把想法做出来</li>
                <li>把页面调顺眼</li>
              </ul>
              <div class="skills-note-foot">不保证满级，但一直在升级</div>
            </div>
          </div>
        </section>

        <!-- 造轮子动机书 -->
        <section class="motive-section">
          <div class="motive-inner">
            <div class="motive-stamp-wrap">
              <div class="section-label">为什么要做这个</div>
              <div class="motive-stamp">WHY</div>
            </div>
            <blockquote class="motive-quote">
              <p>刷热榜这件事，本来应该很轻：看一眼今天大家在聊什么，知道个大概，然后继续干自己的活。</p>
              <p>但现实经常是，微博看完跳知乎，知乎看完跳 B 站，手指越划越熟练，人也越来越不清醒。</p>
              <p>所以我把公开热榜整理到一起。这里不抓正文、不做摘要、不写观点，标题和链接都回到原站。它更像一张贴在桌角的小抄，提醒你今天外面热闹到哪一步了。</p>
              <p class="motive-aside">美股大盘也放了一块，因为成年人总要关心一点账户情绪。<br/><small>仅供信息展示，不构成投资建议。</small></p>
            </blockquote>
            <!-- 小鱼装饰 -->
            <svg class="deco-fish" viewBox="0 0 80 50" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <ellipse cx="38" cy="25" rx="26" ry="14" fill="var(--blue-soft)" stroke="var(--ink)" stroke-width="2"/>
              <path d="M64 25 L78 14 L78 36 Z" fill="var(--blue-soft)" stroke="var(--ink)" stroke-width="2" stroke-linejoin="round"/>
              <circle cx="20" cy="21" r="3" fill="var(--ink)"/>
              <path d="M30 20 Q34 17 38 20" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              <circle cx="21" cy="21" r="1" fill="var(--paper)"/>
            </svg>
          </div>
        </section>

        <!-- 联系本鱼 -->
        <section class="contact-section">
          <div class="section-label">联系本鱼</div>
          <div class="contact-grid">
            <div class="contact-left">
              <p class="contact-intro">看到错漏、想加平台、或者只是想交换一个小工具脑洞，都可以来找我。消息不一定秒回，但看到了会认真看。</p>
              <div class="contact-chips">
                <div class="chip qq-chip">
                  <div class="chip-label">站长 QQ</div>
                  <div class="chip-value">377584613</div>
                  <div class="chip-hint">加好友请备注「摸鱼热榜」</div>
                </div>
                <div class="chip group-chip">
                  <div class="chip-label">摸鱼小群</div>
                  <div class="chip-value">897355748</div>
                  <div class="chip-hint">聊热榜、Bug 和奇怪点子</div>
                </div>
              </div>
            </div>
            <div class="contact-right">
              <div class="qr-wrap">
                <span class="qr-sticker">SCAN ME</span>
                <img src="/qq-group-qrcod.png" alt="QQ群二维码 · 快乐摸鱼 897355748" class="qr-img" width="140" height="140" />
                <div class="qr-label">快乐摸鱼 · 897355748</div>
              </div>
              <a href="https://qm.qq.com/q/it0wKyr5Di" class="qq-join-btn" target="_blank" rel="noopener noreferrer">
                进群一起摸鱼 →
              </a>
            </div>
          </div>
        </section>

        <!-- 版权与数据声明 -->
        <section class="legal-section">
          <div class="section-label">版权与数据声明</div>
          <div class="legal-card">
            <span class="legal-sticker">NOTICE</span>
            <p>摸鱼热榜展示的标题、热度、排名与链接，均来源于各平台公开可访问的信息。相关内容的版权归原始创作者或发布平台所有。</p>
            <p>本站尊重知识产权，只提供信息索引与跳转服务，不复制、不存储、不转码源站正文、图片、视频或评论内容，也不会生成、篡改任何源站内容。</p>
            <p>若你认为页面中的索引链接涉及侵权或不当展示，请通过本页联系方式联系我们。确认后，我们会尽快处理并移除相关入口。</p>
          </div>
        </section>

        <SiteFooter />

    </div>
  </main>

    <style>
      /* ── Hero ── */
      .hero {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 40px;
        align-items: center;
        margin-top: 28px;
        margin-bottom: 56px;
        position: relative;
        z-index: 2;
      }
      .hero-left { position: relative; }
      .hero-title-wrap { position: relative; display: inline-block; margin-bottom: 8px; }
      .hero-title {
        font-family: "Ma Shan Zheng", cursive;
        font-size: clamp(64px, 9vw, 120px);
        line-height: 1;
        margin: 0;
        position: relative;
        z-index: 1;
      }
      .squiggle {
        position: absolute;
        bottom: -6px;
        left: 0;
        width: 100%;
        height: 18px;
        z-index: 0;
      }
      .hero-lede {
        font-family: "Fraunces", serif;
        font-style: italic;
        font-size: 22px;
        margin: 18px 0 8px;
        opacity: .85;
      }
      .hero-sub {
        font-family: "Space Mono", monospace;
        font-size: 12px;
        letter-spacing: .18em;
        text-transform: uppercase;
        opacity: .5;
        margin: 0;
      }

      /* 名片卡 */
      .hero-right { position: relative; display: flex; justify-content: center; }
      .tape {
        position: absolute;
        width: 60px; height: 22px;
        background: repeating-linear-gradient(45deg, rgba(255,255,255,.55) 0, rgba(255,255,255,.55) 4px, rgba(255,201,60,.35) 4px, rgba(255,201,60,.35) 8px);
        border: 1.5px solid rgba(26,23,20,.2);
        border-radius: 3px;
        z-index: 3;
      }
      .tape-top { top: -10px; left: 50%; transform: translateX(-50%) rotate(-3deg); }
      .namecard {
        background: var(--yellow);
        border: 2.5px solid var(--ink);
        border-radius: 18px;
        box-shadow: 8px 8px 0 var(--ink);
        padding: 28px 32px;
        position: relative;
        min-width: 240px;
        transition: transform .25s cubic-bezier(.2,.7,.2,1), box-shadow .25s;
      }
      .namecard:hover {
        transform: translate(-2px,-3px);
        box-shadow: 10px 11px 0 var(--ink);
      }
      .namecard-role {
        font-family: "ZCOOL KuaiLe", sans-serif;
        font-size: 16px;
        margin-bottom: 12px;
      }
      .namecard-divider {
        border-top: 1.5px dashed var(--ink);
        margin: 10px 0;
        opacity: .5;
      }
      .namecard-site {
        font-family: "Ma Shan Zheng", cursive;
        font-size: 28px;
        line-height: 1.1;
      }
      .namecard-url {
        font-family: "Space Mono", monospace;
        font-size: 11px;
        opacity: .6;
        margin-top: 4px;
        letter-spacing: .08em;
      }
      .namecard-stamp {
        position: absolute;
        bottom: 18px; right: 18px;
        font-family: "Bagel Fat One", sans-serif;
        font-size: 11px;
        letter-spacing: .12em;
        text-align: center;
        line-height: 1.2;
        background: var(--pink);
        color: #fff;
        border: 2px solid var(--ink);
        border-radius: 8px;
        padding: 4px 8px;
        box-shadow: 2px 2px 0 var(--ink);
        transform: rotate(-6deg);
      }

      /* ── 工位档案 ── */
      .profile-section {
        margin-bottom: 56px;
        position: relative;
        z-index: 2;
      }
      .section-label {
        font-family: "ZCOOL KuaiLe", sans-serif;
        font-size: 22px;
        margin-bottom: 20px;
        display: inline-block;
        border-bottom: 3px solid var(--ink);
        padding-bottom: 4px;
      }
      .profile-grid {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 32px;
        align-items: start;
      }
      .profile-text {
        background: var(--paper-deep);
        border: 2.5px solid var(--ink);
        border-radius: 18px;
        box-shadow: 5px 5px 0 var(--ink);
        padding: 28px 32px;
        font-size: 15px;
        line-height: 1.85;
      }
      .profile-text p { margin: 0 0 14px; }
      .profile-text p:last-child { margin-bottom: 0; }
      .profile-quote {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-family: "Fraunces", serif;
        font-style: italic;
        font-size: 14px;
        opacity: .75;
        border-top: 1.5px dashed var(--ink);
        padding-top: 14px;
        margin-top: 14px !important;
      }
      .profile-quote svg { flex-shrink: 0; margin-top: 2px; }

      /* 便利贴 */
      .skills-note {
        background: var(--green-soft);
        border: 2.5px solid var(--ink);
        border-radius: 14px;
        box-shadow: 5px 5px 0 var(--ink);
        padding: 22px 24px;
        transition: transform .25s cubic-bezier(.2,.7,.2,1), box-shadow .25s;
      }
      .skills-note:hover {
        transform: translate(-2px,-3px);
        box-shadow: 8px 9px 0 var(--ink);
      }
      .skills-note-title {
        font-family: "ZCOOL KuaiLe", sans-serif;
        font-size: 18px;
        margin-bottom: 8px;
      }
      .skills-note-divider {
        border-top: 1.5px dashed var(--ink);
        margin: 8px 0 12px;
        opacity: .5;
      }
      .skills-list {
        list-style: none;
        padding: 0; margin: 0;
        font-family: "Space Mono", monospace;
        font-size: 12.5px;
        line-height: 2;
      }
      .skills-list li::before { content: "▸ "; opacity: .6; }
      .skills-note-foot {
        font-size: 10px;
        letter-spacing: .14em;
        text-transform: uppercase;
        opacity: .5;
        margin-top: 12px;
        font-family: "Space Mono", monospace;
      }

      /* ── 造轮子动机书 ── */
      .motive-section {
        margin-bottom: 56px;
        position: relative;
        z-index: 2;
      }
      .motive-inner {
        background: var(--blue-soft);
        border: 2.5px solid var(--ink);
        border-radius: 18px;
        box-shadow: 5px 5px 0 var(--ink);
        padding: 36px 40px;
        position: relative;
        overflow: hidden;
      }
      .motive-stamp-wrap {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
      }
      .motive-stamp {
        font-family: "Bagel Fat One", sans-serif;
        font-size: 13px;
        letter-spacing: .18em;
        background: var(--blue);
        color: #fff;
        border: 2px solid var(--ink);
        border-radius: 8px;
        padding: 4px 12px;
        box-shadow: 3px 3px 0 var(--ink);
        transform: rotate(-3deg);
        animation: wig 4.5s ease-in-out infinite;
      }
      .motive-quote {
        margin: 0;
        padding-left: 20px;
        border-left: 3px dashed var(--ink);
        font-size: 15px;
        line-height: 1.9;
      }
      .motive-quote p { margin: 0 0 12px; }
      .motive-quote p:last-child { margin-bottom: 0; }
      .motive-aside {
        font-family: "Fraunces", serif;
        font-style: italic;
        opacity: .7;
        font-size: 14px;
      }
      .motive-aside small { font-size: 12px; }
      .deco-fish {
        position: absolute;
        bottom: 18px; right: 24px;
        width: 80px; height: 50px;
        transform: rotate(-8deg);
        opacity: .7;
      }

      /* ── 版权与数据声明 ── */
      .legal-section {
        margin-bottom: 56px;
        position: relative;
        z-index: 2;
      }
      .legal-card {
        background: var(--green-soft);
        border: 2.5px solid var(--ink);
        border-radius: 18px;
        box-shadow: 5px 5px 0 var(--ink);
        padding: 28px 32px;
        position: relative;
        transform: rotate(-0.4deg);
        font-size: 14.5px;
        line-height: 1.9;
      }
      .legal-card p {
        margin: 0 0 12px;
      }
      .legal-card p:last-child {
        margin-bottom: 0;
      }
      .legal-sticker {
        position: absolute;
        top: -13px;
        right: 26px;
        font-family: "Bagel Fat One", sans-serif;
        font-size: 10px;
        letter-spacing: .1em;
        background: var(--yellow);
        border: 2px solid var(--ink);
        border-radius: 6px;
        padding: 3px 8px;
        box-shadow: 2px 2px 0 var(--ink);
        transform: rotate(6deg);
      }

      /* ── 联系本鱼 ── */
      .contact-section {
        margin-bottom: 56px;
        position: relative;
        z-index: 2;
      }
      .contact-grid {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 32px;
        align-items: center;
        background: var(--paper-deep);
        border: 2.5px solid var(--ink);
        border-radius: 20px;
        box-shadow: 6px 6px 0 var(--ink);
        padding: 28px 32px;
        transform: none;
      }
      .contact-left {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .contact-intro {
        font-size: 15px;
        line-height: 1.8;
        margin: 0;
        font-family: "Fraunces", serif;
        font-style: italic;
        opacity: .85;
      }
      .contact-chips {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }
      .chip {
        border: 2.5px solid var(--ink);
        border-radius: 14px;
        box-shadow: 4px 4px 0 var(--ink);
        padding: 14px 18px;
        min-width: 160px;
        transition: box-shadow .2s, background-color .2s;
      }
      .chip:hover { box-shadow: 6px 6px 0 var(--ink); }
      .qq-chip { background: var(--pink-soft); }
      .qq-chip:hover { background: var(--pink-soft); }
      .group-chip { background: var(--blue-soft); }
      .group-chip:hover { background: var(--blue-soft); }
      .chip-label {
        font-size: 10px;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--ink);
        opacity: .82;
        font-family: "Space Mono", monospace;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .chip-value {
        font-family: "Space Mono", monospace;
        font-size: 22px;
        font-weight: 700;
        line-height: 1.1;
      }
      .chip-hint {
        font-size: 11px;
        opacity: .55;
        font-family: "Space Mono", monospace;
        margin-top: 3px;
      }
      .chip:hover .chip-label,
      .chip:hover .chip-value,
      .chip:hover .chip-hint {
        font-family: "Space Mono", monospace;
      }

      /* 右侧二维码区 */
      .contact-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
      }
      .qr-wrap {
        position: relative;
        background: var(--paper);
        border: 2.5px solid var(--ink);
        border-radius: 14px;
        box-shadow: 5px 5px 0 var(--ink);
        padding: 12px 12px 8px;
      }
      .qr-sticker {
        position: absolute;
        top: -11px; right: -8px;
        font-family: "Bagel Fat One", sans-serif;
        font-size: 10px;
        letter-spacing: .08em;
        background: var(--yellow);
        border: 2px solid var(--ink);
        border-radius: 6px;
        padding: 2px 7px 3px;
        box-shadow: 2px 2px 0 var(--ink);
        transform: rotate(6deg);
      }
      .qr-img {
        display: block;
        width: 140px; height: 140px;
        border-radius: 6px;
        object-fit: cover;
      }
      .qr-label {
        margin-top: 7px;
        font-family: "Space Mono", monospace;
        font-size: 9.5px;
        letter-spacing: .1em;
        text-transform: uppercase;
        opacity: .55;
        text-align: center;
      }
      .qq-join-btn {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        font-family: "ZCOOL KuaiLe", sans-serif;
        font-size: 16px;
        background: var(--blue);
        color: #fff;
        border: 2.5px solid var(--ink);
        border-radius: 999px;
        padding: 9px 22px;
        box-shadow: 4px 4px 0 var(--ink);
        transition: transform .2s cubic-bezier(.2,.7,.2,1), box-shadow .2s;
        white-space: nowrap;
      }
      .qq-join-btn:hover {
        transform: translate(-2px,-2px);
        box-shadow: 6px 6px 0 var(--ink);
      }

      /* ── 动画 ── */
      @keyframes wig {
        0%, 100% { transform: rotate(-3deg); }
        50% { transform: rotate(3deg); }
      }
      @keyframes blink {
        0%, 40%, 100% { opacity: 1; }
        45%, 55% { opacity: .15; }
      }

      /* ── 响应式 ── */
      @media (max-width: 1100px) {
        .hero { grid-template-columns: 1fr; }
        .hero-right { justify-content: flex-start; }
