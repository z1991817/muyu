---
import { getOffWorkStatus } from "../lib/offwork";
import type { CalendarInfo } from "../lib/types";

interface Props {
  stale?: boolean;
  updatedAt: string;
  calendar?: CalendarInfo;
  activePath?: string;
}

const { stale = false, updatedAt, calendar, activePath = "/" } = Astro.props;
const offWork = getOffWorkStatus(new Date(), calendar);
const calendarJson = JSON.stringify(calendar ?? { isRestDay: false, kind: "workday" });
---

<header class="topbar">
  <div class="stamp">摸鱼 ISSUE №001</div>
  <div class="crumbs">
    <span>公开榜单链接聚合</span>
    <span class:list={["off-work", offWork.closed && "is-closed"]} data-off-work data-calendar={calendarJson}>
      {offWork.closed ? "今日营业结束" : <>距下班 <b>{offWork.countdown}</b></>}
    </span>
    <span>{stale ? "数据延迟" : "数据正常"}</span>
    <span>{updatedAt}</span>
  </div>
  <nav>
    <a class:list={[activePath === "/" && "active"]} href="/">首页</a>
    <a class:list={[activePath === "/trends" && "active"]} href="/trends">热榜</a>
    <a class:list={[activePath === "/market" && "active"]} href="/market">美股</a>
    <a class:list={[activePath === "/about" && "active"]} href="/about">关于我</a>
  </nav>
</header>

<script>
  import { getOffWorkStatus } from "../lib/offwork";

  function render() {
    const el = document.querySelector<HTMLSpanElement>("[data-off-work]");
    if (!el) return;
    const calendar = JSON.parse(el.dataset.calendar ?? '{"isRestDay":false,"kind":"workday"}');
    const status = getOffWorkStatus(new Date(), calendar);
    if (status.closed) {
      el.classList.add("is-closed");
      el.textContent = "今日营业结束";
    } else {
      el.classList.remove("is-closed");
      el.innerHTML = `距下班 <b>${status.countdown}</b>`;
    }
  }

  render();
  setInterval(render, 1000);
</script>

<style>
  .topbar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 14px 16px;
    border: 2.5px solid var(--ink);
    border-radius: 18px;
    box-shadow: 5px 5px 0 var(--ink);
    background: var(--paper-deep);
    transform: rotate(-0.8deg);
  }

  .stamp {
    padding: 4px 10px;
    border: 2px solid var(--ink);
    border-radius: 999px;
    background: var(--pink-soft);
    font-family: "Bagel Fat One", sans-serif;
    transform: rotate(-3deg);
  }

  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 11px;
    align-items: center;
  }

  .off-work b {
    font-family: "Bagel Fat One", sans-serif;
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.04em;
    margin-left: 4px;
    color: var(--pink);
  }

  .off-work.is-closed {
    font-family: "ZCOOL KuaiLe", sans-serif;
    font-size: 13px;
    padding: 2px 8px;
    border: 1.8px solid var(--ink);
    border-radius: 999px;
    background: var(--yellow);
    transform: rotate(-1.5deg);
  }

  nav {
    display: flex;
    gap: 8px;
    font-family: "ZCOOL KuaiLe", sans-serif;
  }

  nav a {
    border: 2px solid var(--ink);
    border-radius: 999px;
    padding: 2px 10px;
    background: var(--paper);
  }

  nav a.active {
    background: var(--yellow);
  }

  @media (max-width: 768px) {
    .topbar {
      transform: none;
      grid-template-columns: 1fr;
    }

    .off-work.is-closed {
      transform: none;
    }
  }
</style>
