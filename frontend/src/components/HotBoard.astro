---
import type { Trend } from "../lib/types";

interface Props {
  title: string;
  platformClass: string;
  items: Trend[];
}

const { title, platformClass, items } = Astro.props;
---

<article class={`board ${platformClass}`}>
  <header class="b-head">
    <h3>{title}</h3>
    <span class="tag">HOT</span>
  </header>
  <ol class="b-list">
    {items.map((item, index) => (
      <li class={index < 3 ? `top${index + 1}` : ""}>
        <a href={item.url} target="_blank" rel="noopener noreferrer">
          <span class="rk">{item.rank || index + 1}</span>
          <span class="ttl">{item.title}</span>
          <span class="heat">{item.heat}</span>
        </a>
      </li>
    ))}
  </ol>
</article>

<style>
  .board {
    border: 2.5px solid var(--ink);
    border-radius: 18px;
    box-shadow: 5px 5px 0 var(--ink);
    padding: 16px;
    transform: rotate(1deg);
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 0.25s cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .board:hover {
    transform: translate(-2px, -3px) rotate(-0.4deg);
    box-shadow: 8px 9px 0 var(--ink);
  }

  .b-weibo { background: #FFE6E1; }
  .b-zhihu { background: #E5EBFF; }
  .b-bili { background: #E2F5FF; }
  .b-douyin { background: var(--ink); color: var(--paper); }
  .b-github { background: #FFF1C2; }
  .b-hupu { background: #FFD9C2; }
  .b-tieba { background: #E6F7E0; }
  .b-douban { background: #F1E2FF; }
  .b-v2ex { background: #FFE9A8; }

  .b-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .b-head h3 {
    margin: 0;
    font-family: "ZCOOL KuaiLe", sans-serif;
    font-size: 22px;
  }

  .tag {
    font-size: 10px;
    letter-spacing: 0.14em;
    border: 2px solid currentColor;
    border-radius: 999px;
    padding: 1px 8px;
  }

  .b-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 340px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--ink) transparent;
  }

  .b-list::-webkit-scrollbar { width: 6px; }
  .b-list::-webkit-scrollbar-track { background: transparent; }
  .b-list::-webkit-scrollbar-thumb { background: var(--ink); border-radius: 999px; }

  .b-list li a {
    display: grid;
    grid-template-columns: 34px 1fr auto;
    gap: 8px;
    font-size: 13px;
    align-items: start;
  }

  .rk {
    font-family: "Bagel Fat One", sans-serif;
    font-size: 18px;
    line-height: 1;
  }

  .ttl {
    text-decoration: underline;
    text-decoration-style: wavy;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 2px;
  }

  .heat {
    opacity: 0.8;
  }

  .top1 .rk { color: var(--pink); }
  .top2 .rk { color: var(--orange); }
  .top3 .rk { color: var(--blue); }

  @media (max-width: 768px) {
    .board { transform: none; }
  }
</style>
